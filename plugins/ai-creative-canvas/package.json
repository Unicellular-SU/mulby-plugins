{
  "name": "ai-creative-canvas",
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "dev": "mulby dev",
    "test": "npm run test:compile && npm run test:refs && npm run test:studio && npm run test:graph && npm run test:engine",
    "test:compile": "esbuild test/videoEdit/run-compile.test.ts --bundle --platform=node --format=esm --outfile=dist/run-compile.test.mjs && node dist/run-compile.test.mjs",
    "test:refs": "esbuild test/references.test.ts --bundle --platform=node --format=esm --outfile=dist/references.test.mjs && node dist/references.test.mjs",
    "test:studio": "esbuild test/store/studioStore.test.ts --bundle --platform=node --format=esm --outfile=dist/studioStore.test.mjs && node dist/studioStore.test.mjs",
    "test:graph": "esbuild test/store/graphStore.test.ts --bundle --platform=node --format=esm --outfile=dist/graphStore.test.mjs && node dist/graphStore.test.mjs",
    "test:engine": "esbuild test/providers/engine.test.ts --bundle --platform=node --format=esm --outfile=dist/engine.test.mjs && node dist/engine.test.mjs",
    "test:export": "esbuild src/ui/services/videoEdit/compile.ts --bundle --platform=node --format=esm --outfile=dist/compile.mjs && node test/videoEdit/run-export.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.test.json",
    "build": "npm run typecheck && npm run build:backend && npm run build:ui",
    "build:backend": "esbuild src/main.ts --bundle --platform=node --outfile=dist/main.js",
    "build:ui": "vite build",
    "pack": "npm run build && mulby pack"
  },
  "dependencies": {
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/three": "^0.169.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.27.4",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.3.1"
  }
}
