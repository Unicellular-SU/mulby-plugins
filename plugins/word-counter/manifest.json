{
  "id": "word-counter",
  "name": "word-counter",
  "version": "1.0.1",
  "author": "mulby",
  "type": "productivity",
  "displayName": "字数统计",
  "description": "统计文本的字符数、汉字数、英文词数、句子、段落与阅读时间",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "permissions": {
    "clipboard": true,
    "notification": true
  },
  "pluginSetting": {
    "single": true,
    "height": 680,
    "background": true,
    "persistent": true
  },
  "window": {
    "width": 920,
    "height": 720,
    "minWidth": 560,
    "minHeight": 520,
    "maxWidth": 1400,
    "maxHeight": 1000
  },
  "features": [
    {
      "code": "count-selection",
      "explain": "统计当前选中文本",
      "mode": "ui",
      "mainPush": true,
      "cmds": [
        {
          "type": "over",
          "label": "统计字数",
          "minLength": 50
        }
      ]
    }
  ]
}