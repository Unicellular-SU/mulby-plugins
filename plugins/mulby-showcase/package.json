    "test:layout": "node scripts/test-window-log-layout.mjs",
    "test:window-init": "node scripts/test-child-window-init-listener.mjs",
    "test:child-window-size": "node scripts/test-child-window-create-size.mjs",
    "test:child-message-layout": "node scripts/test-child-window-message-log-layout.mjs",
    "test:child-close-sync": "node scripts/test-child-window-close-sync.mjs",
    "test:inbrowser-serialization": "node scripts/test-inbrowser-serialization-safe.mjs",
    "test:ffmpeg-layout": "node scripts/test-ffmpeg-layout-width.mjs",
    "test:settings-modernization": "node scripts/test-settings-module-modernization.mjs",
    "test:security-storage-modernization": "node scripts/test-security-storage-modernization.mjs",
    "test:ai-module-modernization": "node scripts/test-ai-module-modernization.mjs",
    "test:scheduler-module-modernization": "node scripts/test-scheduler-module-modernization.mjs",
    "test:messaging-module-modernization": "node scripts/test-messaging-module-modernization.mjs",
    "test:host-rpc-module-modernization": "node scripts/test-host-rpc-module-modernization.mjs",
    "test:plugin-orchestration-module-modernization": "node scripts/test-plugin-orchestration-module-modernization.mjs",
    "test:dynamic-features-module-modernization": "node scripts/test-dynamic-features-module-modernization.mjs",
    "test:log-module-modernization": "node scripts/test-log-module-modernization.mjs",
    "test:dialog-modal-modernization": "node scripts/test-dialog-modal-modernization.mjs",
    "test:input-window-restore": "node scripts/test-input-window-restore.mjs",
    "build": "npm run build:backend && npm run build:ui",
    "build:backend": "esbuild src/main.ts --bundle --platform=node --outfile=dist/main.js",
    "build:ui": "vite build",
    "pack": "mulby pack"
  },
  "dependencies": {
    "lucide-react": "^1.14.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
