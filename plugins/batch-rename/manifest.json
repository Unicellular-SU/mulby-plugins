{
  "$schema": "./node_modules/.mulby/manifest-schema.json",
  "id": "batch-rename",
  "name": "batch-rename",
  "version": "1.0.0",
  "author": "mulby",
  "type": "utility",
  "displayName": "批量重命名",
  "description": "工业级文件重命名工具，支持复杂逻辑的批量处理",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "permissions": {
    "clipboard": true,
    "notification": true
  },
  "window": {
    "width": 900,
    "height": 650,
    "minWidth": 600,
    "minHeight": 500,
    "maxWidth": 1600,
    "maxHeight": 1200,
    "type": "default"
  },
  "features": [
    {
      "code": "batch-rename",
      "explain": "批量重命名文件",
      "cmds": [
        {
          "type": "keyword",
          "value": "批量重命名"
        },
        {
          "type": "keyword",
          "value": "rename"
        },
        {
          "type": "files",
          "fileType": "any",
          "minLength": 1
        }
      ]
    }
  ]
}
