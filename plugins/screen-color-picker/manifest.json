{
  "id": "screen-color-picker",
  "name": "screen-color-picker",
  "version": "1.0.1",
  "author": "mulby",
  "type": "utility",
  "displayName": "屏幕取色器",
  "description": "从屏幕任意位置拾取颜色，支持 HEX/RGB/HSL 复制与历史色板。",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "pluginSetting": {
    "single": true,
    "height": 640
  },
  "window": {
    "width": 500,
    "height": 640,
    "minWidth": 420,
    "minHeight": 560
  },
  "features": [
    {
      "code": "open_color_picker",
      "explain": "打开屏幕取色器",
      "mode": "ui",
      "cmds": [
        {
          "type": "keyword",
          "value": "屏幕取色"
        },
        {
          "type": "keyword",
          "value": "取色器"
        },
        {
          "type": "keyword",
          "value": "color picker"
        },
        {
          "type": "keyword",
          "value": "pick color"
        }
      ]
    },
    {
      "code": "recognize-color",
      "explain": "识别并预览颜色值",
      "mode": "ui",
      "cmds": [
        {
          "type": "regex",
          "label": "识别颜色值",
          "match": "^(#(?:[0-9a-fA-F]{3}|[0-9a-fA-F]{6}|[0-9a-fA-F]{8})|rgba?\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*,\\s*\\d{1,3}\\s*(?:,\\s*(?:0?\\.\\d+|1(?:\\.0)?|[01]))?\\)|hsla?\\(\\s*\\d{1,3}\\s*,\\s*\\d{1,3}%\\s*,\\s*\\d{1,3}%\\s*(?:,\\s*(?:0?\\.\\d+|1(?:\\.0)?|[01]))?\\))$",
          "minLength": 4,
          "explain": "匹配 HEX / RGB / HSL 颜色值"
        },
        {
          "type": "over",
          "label": "识别颜色值",
          "minLength": 4,
          "exclude": "^[A-Za-z\\u4e00-\\u9fff\\s]+$"
        }
      ]
    }
  ]
}