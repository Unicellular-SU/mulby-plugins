{
  "$schema": "./node_modules/.mulby/manifest-schema.json",
  "id": "hot-trending",
  "name": "hot-trending",
  "version": "1.0.0",
  "author": "mulby",
  "type": "entertainment",
  "displayName": "热搜排行榜",
  "description": "聚合多平台热搜榜，快捷键驱动，工作之余方便吃瓜",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "permissions": {
    "notification": true,
    "webview": true
  },
  "window": {
    "width": 800,
    "height": 600,
    "minWidth": 500,
    "minHeight": 400,
    "type": "default"
  },
  "features": [
    {
      "code": "hot-trending",
      "explain": "查看实时热搜排行榜",
      "cmds": [
        { "type": "keyword", "value": "热搜" },
        { "type": "keyword", "value": "hot" },
        { "type": "keyword", "value": "resou" }
      ]
    }
  ]
}
