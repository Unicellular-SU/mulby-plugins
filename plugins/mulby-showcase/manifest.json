{
  "id": "@mulby/showcase",
  "name": "mulby-showcase",
  "version": "1.0.1",
  "displayName": "Mulby 功能展示",
  "description": "综合展示 Mulby 所有 API 能力的示例插件，涵盖系统信息、剪贴板、文件管理、网络、屏幕捕获、媒体、高级设置和安全存储等功能",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "author": "Mulby",
  "homepage": "https://github.com/Unicellular-SU/mulby_plugins",
  "minAppVersion": "1.0.0",
  "permissions": {
    "geolocation": true,
    "clipboard": true,
    "accessibility": true,
    "screen": true,
    "microphone": true,
    "camera": true,
    "notification": true
  },
  "pluginSetting": {
    "background": true,
    "persistent": true,
    "idleTimeoutMs": "never"
  },
  "window": {
    "width": 1180,
    "height": 760,
    "minWidth": 920,
    "minHeight": 620,
    "backgroundThrottling": false
  },
  "features": [
    {
      "code": "main",
      "explain": "打开功能展示面板",
      "cmds": [
        {
          "type": "keyword",
          "value": "showcase"
        },
        {
          "type": "keyword",
          "value": "demo"
        },
        {
          "type": "keyword",
          "value": "示例"
        },
        {
          "type": "keyword",
          "value": "功能展示"
        }
      ]
    },
    {
      "code": "screenshot",
      "explain": "区域截图并进入图片编辑",
      "preCapture": "region",
      "cmds": [
        {
          "type": "keyword",
          "value": "sc"
        },
        {
          "type": "keyword",
          "value": "截图"
        },
        {
          "type": "keyword",
          "value": "screenshot"
        }
      ]
    },
    {
      "code": "sysinfo",
