{
  "id": "mulby-developer-tools",
  "name": "mulby-developer-tools",
  "version": "1.0.0",
  "type": "developer",
  "displayName": "Mulby 开发者工具",
  "description": "插件开发工作台：创建/导入/构建/打包/刷新/管理插件，并支持 AI Vibe Coding 一句话造插件",
  "author": "Mulby",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "features": [
    {
      "code": "workbench",
      "explain": "打开插件开发工作台",
      "mode": "detached",
      "cmds": [
        { "type": "keyword", "value": "开发者工具" },
        { "type": "keyword", "value": "dev" },
        { "type": "keyword", "value": "developer" }
      ]
    }
  ],
  "window": {
    "type": "default",
    "width": 1100,
    "height": 720,
    "minWidth": 880,
    "minHeight": 560
  },
  "permissions": {
    "shell": true,
    "clipboard": true,
    "notification": true,
    "runCommand": true,
    "commandExecution": {
      "direct": {
        "enabled": true,
        "defaultProfile": "workspace",
        "maxProfile": "trusted"
      },
      "ai": {
        "enabled": true
      }
    },
    "envKeys": ["PATH", "HOME", "NODE_ENV"]
  },
  "pluginSetting": {
    "single": true,
    "height": 720,
    "background": false,
    "persistent": false,
    "defaultDetached": true
  }
}
