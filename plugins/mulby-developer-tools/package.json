{
  "name": "mulby-developer-tools",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/sync-schema.mjs",
    "build": "npm run build:backend && npm run build:ui",
    "build:backend": "esbuild src/main.ts --bundle --platform=node --target=node22 --external:@colbymchenry/codegraph --outfile=dist/main.js",
    "build:ui": "vite build",
    "sync:schema": "node scripts/sync-schema.mjs",
    "pack": "npm run build && mulby pack"
  },
  "dependencies": {
    "@colbymchenry/codegraph": "^0.9.9",
    "ajv": "^8.20.0",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.20.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.3.1"
  }
}
