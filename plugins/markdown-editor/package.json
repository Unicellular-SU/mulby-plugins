{
  "name": "markdown-editor",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "mulby dev",
    "build": "npm run build:backend && npm run build:ui",
    "build:backend": "esbuild src/main.ts --bundle --platform=node --outfile=dist/main.js",
    "build:ui": "vite build",
    "test:unit": "esbuild src/ui/services/search.test.ts --bundle --platform=node --format=esm --outfile=dist/search.test.mjs && node dist/search.test.mjs",
    "pack": "npm run build && mulby pack"
  },
  "dependencies": {
    "@toast-ui/editor": "^3.2.2",
    "docx": "^9.5.1",
    "lucide-react": "^0.562.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.21.5",
    "mulby-cli": "^1.2.5",
    "typescript": "^5.2.2",
    "vite": "^5.3.1"
  }
}
