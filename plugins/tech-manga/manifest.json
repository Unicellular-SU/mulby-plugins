{
  "id": "tech-manga",
  "name": "tech-manga",
  "version": "1.0.0",
  "author": "Unicellular-SU",
  "type": "ai",
  "displayName": "技术漫画生成器",
  "description": "AI 技术漫画生成器：把技术文档、Bug 报告、历史事件或人物传记改编成漫画——自动编写分页脚本、生成角色与道具设定图，并逐页绘制带中文对白的漫画（20+ 画风、动漫角色客串演绎）",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "window": {
    "width": 1280,
    "height": 820,
    "minWidth": 960,
    "minHeight": 640,
    "type": "default"
  },
  "pluginSetting": {
    "single": true
  },
  "features": [
    {
      "code": "tech-manga-open",
      "explain": "打开技术漫画生成器 - 把技术文档/历史事件改编成漫画",
      "mode": "detached",
      "cmds": [
        { "type": "keyword", "value": "技术漫画" },
        { "type": "keyword", "value": "科技漫画" },
        { "type": "keyword", "value": "techmanga" }
      ]
    }
  ]
}
