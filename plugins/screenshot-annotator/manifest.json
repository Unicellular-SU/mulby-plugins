{
  "id": "screenshot-annotator",
  "name": "screenshot-annotator",
  "version": "1.2.1",
  "author": "mulby",
  "type": "productivity",
  "displayName": "截图标注",
  "description": "区域截图后在透明独立窗口中快速添加矩形、箭头和画笔标注，结果可复制、保存为 PNG 或钉在屏幕最上层；内置「问 AI」可对截图解释、解题、提取文字、翻译或 AI 修图。",
  "main": "dist/main.js",
  "ui": "ui/index.html",
  "icon": "icon.png",
  "permissions": {
    "screen": true,
    "clipboard": true,
    "notification": true
  },
  "pluginSetting": {
    "single": false,
    "height": 96,
    "defaultDetached": true
  },
  "window": {
    "type": "borderless",
    "titleBar": false,
    "transparent": true,
    "resizable": true,
    "alwaysOnTop": true,
    "position": "capture-region",
    "fit": "capture-region-with-toolbar",
    "captureToolbarHeight": 96,
    "width": 1080,
    "height": 636,
    "minWidth": 1080,
    "minHeight": 120,
    "maxWidth": 4096,
    "maxHeight": 4096
  },
  "features": [
    {
      "code": "annotate",
      "explain": "截图标注",
      "mode": "detached",
      "preCapture": "region",
      "cmds": [
        {
          "type": "keyword",
          "value": "截图标注"
        },
        {
          "type": "keyword",
          "value": "sc"
        }
      ]
    },
    {
      "code": "history",
      "explain": "截图历史",
      "mode": "detached",
      "route": "/index.html?mode=history",
      "cmds": [
        {
          "type": "keyword",
          "value": "截图历史"
        },
        {
          "type": "keyword",
          "value": "sch"
        }
      ]
    }
  ]
}