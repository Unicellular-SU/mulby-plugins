{
  "name": "markdown-editor",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "mulby dev",
    "build": "npm run build:backend && npm run build:ui",
    "build:backend": "esbuild src/main.ts --bundle --platform=node --outfile=dist/main.js",
    "build:ui": "vite build",
    "test:unit": "esbuild src/ui/services/test-runner.ts --bundle --platform=node --format=esm --outfile=dist/test-runner.mjs && node dist/test-runner.mjs",
    "pack": "npm run build && mulby pack"
  },
  "dependencies": {
    "@codemirror/commands": "^6.3.3",
    "@codemirror/lang-markdown": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.23.0",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.4",
    "docx": "^9.5.1",
    "lucide-react": "^0.562.0",
    "markdown-it": "^14.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.21.5",
    "mulby-cli": "^1.2.5",
    "typescript": "^5.2.2",
    "vite": "^5.3.1"
  }
}
