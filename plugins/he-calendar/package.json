{
  "name": "he-calendar",
  "version": "1.3.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:backend && npm run build:ui",
    "build:backend": "esbuild src/main.ts --bundle --platform=node --outfile=dist/main.js --external:tyme4ts",
    "build:ui": "vite build",
    "preview": "vite preview",
    "pack": "npm run build && mulby pack"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "dayjs": "^1.11.19",
    "lucide-vue-next": "^0.563.0",
    "tyme4ts": "^1.4.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "esbuild": "^0.25.0",
    "utools-api-types": "^6.1.0",
    "vite": "^6.0.11"
  }
}
